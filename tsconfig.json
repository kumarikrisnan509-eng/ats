{
  "//": "Phase B-1: gradual JSDoc typecheck.",
  "//1": "checkJs ON for files that opt in via `// @ts-check` at the top.",
  "//2": "noEmit -- this is a lint pass, not a build. The browser still loads the .js files esbuild emits.",
  "//3": "allowJs + jsx: preserve lets tsc parse our React-via-window-globals .jsx without React/JSX runtime imports.",
  "//4": "include is narrow on purpose -- expand as more files adopt @ts-check.",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "types": [],
    "moduleDetection": "force"
  },
  "include": [
    "src/screen-ai-advisor.jsx",
    "src/screen-ai-keys.jsx",
    "src/screen-ai-review.jsx",
    "src/screen-attribution.jsx",
    "src/screen-audit.jsx",
    "src/screen-auth.jsx",
    "src/screen-brokers.jsx",
    "src/screen-calibration.jsx",
    "src/screen-compliance.jsx",
    "src/screen-dashboard.jsx",
    "src/screen-landing.jsx",
    "src/screen-long-term.jsx",
    "src/screen-macro-signals.jsx",
    "src/screen-margin.jsx",
    "src/screen-modes.jsx",
    "src/screen-money.jsx",
    "src/screen-onboarding.jsx",
    "src/screen-options-opportunities.jsx",
    "src/screen-paper.jsx",
    "src/screen-portfolio.jsx",
    "src/screen-recon.jsx",
    "src/screen-risk-cockpit.jsx",
    "src/screen-risk-config.jsx",
    "src/screen-risk.jsx",
    "src/screen-settings.jsx",
    "src/screen-signals.jsx",
    "src/screen-sip.jsx",
    "src/screen-slippage.jsx",
    "src/screen-stp-swp.jsx",
    "src/screen-strategies.jsx",
    "src/screen-trading.jsx",
    "src/screen-walk-forward.jsx",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "deploy/backend/node_modules",
    "test-e2e",
    "out",
    ".local-dev",
    ".ci-tmp"
  ]
}
