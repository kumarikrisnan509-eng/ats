{
  "name": "ats-local-dev",
  "version": "1.0.0",
  "private": true,
  "description": "Local dev orchestrator for ATS. Spawns backend + JSX watcher + static-server in one terminal.",
  "scripts": {
    "dev": "node scripts/dev-server.js",
    "transform": "node deploy/build/transform.js",
    "transform:watch": "node deploy/build/transform.js --watch",
    "test:local": "node scripts/test-local.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "esbuild": "0.21.5",
    "typescript": "5.4.5"
  }
}
