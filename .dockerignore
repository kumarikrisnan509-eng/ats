# Anything not needed inside the image. Keeps build context tiny.

# VCS
.git
.gitignore
.github

# Editor / OS
.vscode
.idea
.DS_Store
Thumbs.db
*.swp

# Node
node_modules
deploy/backend/node_modules
**/node_modules

# Audit logs / secrets / sealed tokens — MUST NOT enter the image
audit.log
**/audit.log
deploy/backend/master.key
deploy/backend/tokens/
deploy/backend/.env
deploy/backend/.env.*
!deploy/backend/.env.example

# T-456 (audit-2026-05-26 infra L6): block any stray key/cert from
# entering the image, no matter where it lands in the build context.
# These patterns are belt-and-suspenders for the operator who might
# leave a local debugging key alongside the source.
*.key
**/*.key
*.pem
**/*.pem
*.crt
**/*.crt
.secrets-local/
**/.secrets-local/

# Build artefacts
dist
build

# Design assets we don't ship to the live site
screenshots
uploads
debug.png

# v1 deliverables (kept in the repo for reference, not in the image)
../rajasekarselvam.com

# Misc
README*.md
ANALYSIS*.md
*.log
