# ATS backend config — rajasekarselvam.com
# Copy to /etc/ats/backend.env on the server. chmod 600. owner root:ats.
# NEVER commit the real file to git.

# Label that shows up in audit log and /api/health.
ENV_NAME=prod

# Port the Node server binds to (loopback). Nginx proxies to this.
PORT=8080

# Order-execution kill switch. Default true. Affects only /api/orders/dry-run path.
# This scaffold does not place real orders regardless of this flag.
KILL_SWITCH=true

# Where the append-only audit log is written. Owned by service user `ats`.
AUDIT_LOG=/var/log/ats/audit.log

# Cap concurrent WebSocket clients to the front-end.
MAX_WS_CLIENTS=200

# ===== Broker selection =====
# "mock"     -> built-in random-walk simulator (default; no Zerodha account needed)
# "zerodha"  -> Kite Connect realtime feed (requires Kite Connect subscription + OAuth)
BROKER=mock

# ===== Zerodha (only used when BROKER=zerodha) =====
# Get these from https://developers.kite.trade/ after creating an "App".
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
# Must match the redirect URL configured on the Kite developer console for this app.
ZERODHA_REDIRECT_URL=https://ats.rajasekarselvam.com/api/brokers/zerodha/callback

# ===== Token vault =====
# 32-byte master key for libsodium secretbox.
# Generate once during setup:
#   sudo -u ats MASTER_KEY_PATH=/etc/ats/master.key node -e "require('/opt/ats/backend/crypto-vault').writeNewMasterKey('/etc/ats/master.key')"
# Then chmod 400 it. Never commit. Lose it and you'll need every user to reconnect.
MASTER_KEY_PATH=/etc/ats/master.key

# Encrypted per-user Zerodha access_token blobs live here. Owned by user `ats`, mode 700.
TOKENS_DIR=/var/lib/ats/tokens

# ===== Frontend ↔ backend session cookie =====
# A long random string used to sign the session cookie. Rotate every quarter.
SESSION_SECRET=change-me-to-32-random-bytes-base64

# Default symbols the mock broker advertises. Comma-separated. (Real Zerodha would use
# instrument tokens fetched from the daily instruments dump — see plan doc §3.)
DEFAULT_SYMBOLS=NIFTY 50,BANKNIFTY,RELIANCE,HDFCBANK,TCS,INFY
