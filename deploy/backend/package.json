{
  "name": "ats-backend",
  "version": "0.2.0",
  "description": "ATS backend",
  "private": true,
  "main": "server.js",
  "engines": { "node": ">=20" },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
