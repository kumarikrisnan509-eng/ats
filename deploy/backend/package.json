{
  "name": "ats-backend",
  "version": "0.3.0",
  "description": "ATS backend",
  "private": true,
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node test/_runner.js",
    "migrate": "node migrate-from-json.js",
    "init-master-key": "node -e \"require('./crypto-vault').writeNewMasterKey(process.env.MASTER_KEY_PATH || '/etc/ats/master.key').then(p => console.log('wrote', p))\"",
    "lock:check": "npm ci --dry-run --ignore-scripts --no-audit --no-fund"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "kiteconnect": "^4.1.0",
    "libsodium-wrappers": "^0.7.13",
    "cookie": "^0.7.0",
    "better-sqlite3": "^11.5.0",
    "bcrypt": "^5.1.1",
    "otplib": "^12.0.1",
    "nodemailer": "^6.9.16"
  }
}
