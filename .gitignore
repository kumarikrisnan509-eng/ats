# ===== Secrets — NEVER commit these =====
# Anything containing broker keys, session secrets, or master keys.
.env
.env.*
!.env.example
deploy/backend/.env
deploy/backend/.env.*
!deploy/backend/.env.example

# libsodium master key (encrypts Zerodha access tokens at rest)
master.key
deploy/backend/master.key
deploy/master.key

# Sealed per-user access tokens (one .enc file per user)
tokens/
deploy/backend/tokens/

# SSH keys (deploy user)
id_rsa
id_ed25519
*.pem
*.key
# (Exception: re-allow public keys you might want to ship in /docs)
!*.pub

# Local-only secrets scratch dir (deploy SSH keys, known_hosts captures, etc.)
.secrets-local/
ats-deploy
ats-deploy.pub

# Local helper .cmd files (hardcoded VM IPs, key paths). Not for shipping.
BOOTSTRAP-VM.cmd
KEYSCAN.cmd
COPY-KNOWN-HOSTS.cmd
PUSH-TO-GITHUB.cmd
PUSH-NOW.cmd
UPDATE-VM.cmd
FIX-VM-PERMS.cmd
FIX-PERMS-AND-RESTART.cmd
DIAG-VM.cmd
DIAG2.cmd
ANALYZE-VM.cmd
CLEANUP-VM.cmd
SETUP-RCLONE-ARCHIVE.cmd
ENABLE-AND-TEST-ARCHIVE.cmd
FIX-LOGROTATE-SU.cmd
TEST-EVERYTHING.cmd
TEST-VM.cmd
SET-ZERODHA.cmd
FORCE-RECREATE.cmd
DIAG-ZERODHA.cmd
WIRE-ZERODHA.cmd
deploy/.wire-zerodha-output.txt
# wire-zerodha-fully.ps1 contains embedded API key + secret (gitignored)
deploy/scripts/wire-zerodha-fully.ps1
WIRE-ZERODHA-PROPERLY.cmd
deploy/.wire-zerodha-properly-output.txt
deploy/scripts/wire-zerodha-properly.ps1
FORCE-PULL.cmd
deploy/.force-pull-output.txt
RECOVER.cmd
deploy/.recover-output.txt
deploy/scripts/recover-and-zerodha.ps1
FIX-MASTERKEY.cmd
deploy/.fix-masterkey-output.txt
# set-zerodha-env.ps1 contains embedded API key+secret (after the user creates the Kite app).
deploy/scripts/set-zerodha-env.ps1
deploy/.vm-analysis.txt
deploy/.vm-test-output.txt
deploy/.bootstrap.log

# ===== Logs =====
audit.log
deploy/backend/audit.log
*.log
logs/

# ===== Node =====
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
.npm

# ===== Build artefacts =====
dist/
build/
.cache/
.parcel-cache/
.next/
out/

# ===== Local dev =====
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ===== Local test outputs / Claude session scratch =====
deploy/backend/audit.log
deploy/backend/master.key
deploy/backend/tokens/

# ===== Design assets we keep locally but don't want in CI / docker context =====
# (Comment any of these out if you DO want them in the repo for reference.)
debug.png

# We DO keep screenshots/uploads in the repo for documentation, but they don't go
# into the Docker image — that's handled by .dockerignore.

# ===== OS / editor cruft =====
*.bak
*~
